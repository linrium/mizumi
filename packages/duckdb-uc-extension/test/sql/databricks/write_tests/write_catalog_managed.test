# name: test/sql/databricks/write_tests/write_catalog_managed.test
# description: test
# group: [write_tests]

# Require statement will ensure this test is run with this extension loaded
require parquet

require unity_catalog

require delta

require httpfs

require-env DATABRICKS_TOKEN

require-env DATABRICKS_ENDPOINT

require-env DATABRICKS_REGION

require-env DATABRICKS_WRITE_TEST_CATALOG

require-env DATABRICKS_WRITE_TEST_SCHEMA

require-env RUN_WRITE_TESTS

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CREATE SECRET (
    TYPE unity_catalog,
    TOKEN '${DATABRICKS_TOKEN}',
    ENDPOINT '${DATABRICKS_ENDPOINT}',
    AWS_REGION '${DATABRICKS_REGION}'
);

# Attach to databricks through the unity catalog API
statement ok
ATTACH '${DATABRICKS_WRITE_TEST_CATALOG}' AS databricks_catalog (TYPE unity_catalog, DEFAULT_SCHEMA '${DATABRICKS_WRITE_TEST_SCHEMA}');

statement ok
USE databricks_catalog;

statement ok
CALL enable_logging(level='debug');

statement ok
SET VARIABLE table_path = (FROM databricks_catalog.table_data_path('simple_table_catalog_managed'));

query I
SELECT * FROM simple_table_catalog_managed ORDER BY id;
----
1
2
3
4
5

statement ok
INSERT INTO simple_table_catalog_managed VALUES (10);

statement ok
INSERT INTO simple_table_catalog_managed VALUES (11);

query I
SELECT * FROM simple_table_catalog_managed ORDER BY id
----
1
2
3
4
5
10
11

# List the staged commits to the table
query I
SELECT parse_filename(file)[0:21] AS f FROM GLOB(getvariable('table_path') || '/_delta_log/_staged_commits/**/*') ORDER BY f;
----
00000000000000000001.
00000000000000000002.

# -----------------------------------------------------------------------------
# Backfill verification (delta.yaml v1).
# Under v1 each add-commit POST carries the table UUID (assert-table-uuid) and,
# once a watermark exists, a set-latest-backfilled-version update (UCAPI::UpdateTable).
# There is no longer a pending-backfill queue: a read marks the table dirty, the next
# InternalAttach calls LoadTable, and BackfillCommits copies each outstanding staged
# commit into _delta_log/ while advancing the backfilled_through watermark.
# 3 iterations confirm the pattern repeats.
#

loop i 0 3

statement ok
INSERT INTO simple_table_catalog_managed VALUES (1000 + {i});

endloop

# count(*) = 10 confirms all 5 DuckDB commits are visible. (Reads resolve via the
# log_tail handed to the kernel even before backfill; the _delta_log/ assertion
# below is what actually proves BackfillCommits copied the staged commits.)
query I
SELECT count(*) FROM simple_table_catalog_managed;
----
10

# All 5 staged commits present (v1-v2 from initial inserts above, v3-v5 from loop).
# Staged files are copied (not moved) on backfill, so they remain until VACUUM.
query I
SELECT parse_filename(file)[0:21] AS f FROM GLOB(getvariable('table_path') || '/_delta_log/_staged_commits/**/*') ORDER BY f;
----
00000000000000000001.
00000000000000000002.
00000000000000000003.
00000000000000000004.
00000000000000000005.

# v1 backfill effect: each staged commit is copied to a regular (non-staged)
# _delta_log/NNN.json entry (clean %020llu.json name, no UUID suffix). All 5 DuckDB
# versions must appear; the version-0 creation commit is excluded by the f filter.
query I
SELECT parse_filename(file)[0:21] AS f FROM GLOB(getvariable('table_path') || '/_delta_log/*.json')
WHERE f >= '00000000000000000001.' ORDER BY f;
----
00000000000000000001.
00000000000000000002.
00000000000000000003.
00000000000000000004.
00000000000000000005.

# -----------------------------------------------------------------------------
# v1 add-commit protocol — assert-table-uuid + set-latest-backfilled-version.
# These ride in the UpdateTable POST body and aren't visible in the data; they
# surface only in the enriched uc-api.UpdateTable debug log line.
#

# Every add-commit carries the table UUID (assert-table-uuid requirement).
query I
SELECT count(*) > 0 FROM duckdb_logs()
WHERE message LIKE 'uc-api.UpdateTable %simple_table_catalog_managed %table_id=%'
  AND message NOT LIKE '%table_id=(none)%';
----
true

# Once a read advances the backfill watermark, later commits carry
# set-latest-backfilled-version (numeric backfill_version, not "(none)").
query I
SELECT count(*) > 0 FROM duckdb_logs()
WHERE message LIKE 'uc-api.UpdateTable %simple_table_catalog_managed %backfill_version=%'
  AND message NOT LIKE '%backfill_version=(none)%';
----
true
