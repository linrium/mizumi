# name: test/sql/databricks/basic.test
# description: test
# group: [databricks]

# Require statement will ensure this test is run with this extension loaded
require parquet

require unity_catalog

require delta

require httpfs

require-env DATABRICKS_TOKEN

require-env DATABRICKS_ENDPOINT

require-env DATABRICKS_REGION

statement ok
CREATE SECRET (
    TYPE unity_catalog,
    TOKEN '${DATABRICKS_TOKEN}',
    ENDPOINT '${DATABRICKS_ENDPOINT}',
    AWS_REGION '${DATABRICKS_REGION}'
);

# Attach to databricks through the unity catalog API
statement ok
ATTACH 'duckdb_testing' (TYPE unity_catalog, READ_ONLY, DEFAULT_SCHEMA 'main');

# Can query a table
query I nosort expected_res
from duckdb_testing.main.simple_table;

statement ok
use duckdb_testing

query I nosort expected_res
from simple_table;

statement ok
use memory

statement ok
DETACH duckdb_testing

# Without a default schema is also possible

# FIXME
mode skip

statement ok
ATTACH 'duckdb_testing' (TYPE unity_catalog);

# Can query a table
query I nosort expected_res
from duckdb_testing.main.simple_table;

# TODO: can we fix this? Or at least throw a nicer error
statement error
use duckdb_testing
----
Catalog Error: SET schema: No catalog + schema named "duckdb_testing" found.

statement ok
use duckdb_testing.main

query I nosort expected_res
from simple_table;
