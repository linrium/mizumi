# name: test/sql/local_oss_unity_catalog/uc_catalog_write.test
# description: write to a plain (non-CMT) EXTERNAL Delta table via UC
# group: [local_oss_unity_catalog]

#
# Writes go to duck.external.id_name_rw — a plain (EXTERNAL, non-catalog-managed) Delta table
# seeded by scripts/oss_uc_local/seed_tables. It is a dedicated _rw write target: no read test
# asserts its exact contents, so accumulated rows across runs are harmless. The sample
# unity.default.* tables are read-only fixtures and must never be written here.

require parquet

require httpfs

require delta

require unity_catalog

require-env UC_TEST_SERVER_RUNNING

statement ok
CREATE SECRET (
    TYPE unity_catalog,
    TOKEN 'not-used',
    ENDPOINT 'http://127.0.0.1:8080',
    AWS_REGION 'us-east-2'
);

statement ok
ATTACH 'duck' AS duck (TYPE unity_catalog, DEFAULT_SCHEMA 'external');

statement ok
CALL enable_logging(level='DEBUG');

# Trigger attach.
statement ok
FROM duck.external.id_name_rw;

statement ok
INSERT INTO duck.external.id_name_rw VALUES (1, 'blabla');

# Second insert verifies PlanInsert credential ordering (RefreshCredentials before
# InternalAttach). EXTERNAL is not catalog-managed, so this is the plain Delta write path.
statement ok
INSERT INTO duck.external.id_name_rw VALUES (2, 'blabla2');

# Both rows are readable (>= the inserts; the table accumulates across runs).
query I
SELECT count(*) > 0 FROM duck.external.id_name_rw WHERE name IN ('blabla', 'blabla2');
----
true

# Non-CMT path: a plain EXTERNAL write commits straight to the Delta log, so the delta.yaml
# v1 commit API (UpdateTable) is NOT called — unlike the catalog-managed path.
query I
SELECT count(*) FROM duckdb_logs()
WHERE message LIKE 'uc-api.UpdateTable duck.external.id_name_rw%';
----
0
