# name: test/sql/local_oss_unity_catalog/managed_catalog.test
# description: read and write on a catalog-managed table via delta.yaml v1 (LoadTable / UpdateTable)
# group: [local_oss_unity_catalog]

#
# Requires a LOCAL (non-docker) OSS UC server (managed tables are on by default), seeded with
# the duck catalog: duck.managed.id_name_{ro,rw} are catalog-managed (CMT) Delta tables.
# See scripts/oss_uc_local/seed_tables. _ro is pre-populated (5 rows) and read-only; _rw is an
# empty write target. The read-only attach reads _ro; the write attach writes _rw.

require parquet

require unity_catalog

require delta

require httpfs

require-env UC_TEST_SERVER_RUNNING

statement ok
CREATE SECRET (
    TYPE unity_catalog,
    TOKEN 'not-used',
    ENDPOINT 'http://127.0.0.1:8080',
    AWS_REGION 'us-east-2'
);

# Sample catalog (read-only) for the non-CMT negative case.
statement ok
ATTACH 'unity' AS uc (TYPE unity_catalog, DEFAULT_SCHEMA 'default', READ_ONLY);

# Read-only attach reads the _ro fixture; nothing writes it.
statement ok
ATTACH 'duck' AS duck_ro (TYPE unity_catalog, DEFAULT_SCHEMA 'managed', READ_ONLY);

# Read-write attach owns the _rw write target.
statement ok
ATTACH 'duck' AS duck (TYPE unity_catalog, DEFAULT_SCHEMA 'managed');

statement ok
CALL enable_logging(level='DEBUG');

# -----------------------------------------------------------------------------
# Non-CMT negative — marksheet is MANAGED in OSS UC but has no catalogManaged
# Delta writer feature, so IsCatalogManaged() is false and LoadTable is NOT called.
#

statement ok
FROM uc.default.marksheet;

query I
SELECT count(*) FROM duckdb_logs()
WHERE message LIKE 'uc-api.LoadTable unity.default.marksheet%';
----
0

# -----------------------------------------------------------------------------
# CMT read (READ_ONLY) — duck.managed.id_name_ro has the catalogManaged feature, so
# InternalAttach calls LoadTable (delta.yaml v1 GET .../tables/{table}).
#

query II
SELECT id, name FROM duck_ro.managed.id_name_ro ORDER BY id;
----
1	one
2	two
3	three
4	four
5	five

query I
SELECT count(*) > 0 FROM duckdb_logs()
WHERE message LIKE 'uc-api.LoadTable duck.managed.id_name_ro%';
----
true

# A read-only attach must NOT backfill — backfill writes to _delta_log/, which a RO attach may not
# do (it also holds only read-scoped credentials). The read still resolves via log_tail.
query I
SELECT count(*) > 0 FROM duckdb_logs()
WHERE message LIKE 'uc.InternalAttach duck.managed.id_name_ro read-only: skipping backfill%';
----
true

# -----------------------------------------------------------------------------
# Read-only invariant — a _ro table attached READ_ONLY rejects writes.
#

statement error
INSERT INTO duck_ro.managed.id_name_ro VALUES (99, 'nope');
----
read-only mode

# -----------------------------------------------------------------------------
# CMT write path — INSERT exercises UpdateTable (delta.yaml v1 add-commit).
#

statement ok
INSERT INTO duck.managed.id_name_rw VALUES (1, 'managed_cat_test');

query I
SELECT count(*) > 0 FROM duckdb_logs()
WHERE message LIKE 'uc-api.UpdateTable duck.managed.id_name_rw%';
----
true

# Conversely, a read-write attach never skips backfill (complement of the RO assertion above).
query I
SELECT count(*) FROM duckdb_logs()
WHERE message LIKE 'uc.InternalAttach duck.managed.id_name_rw read-only%';
----
0

# -----------------------------------------------------------------------------
# v1 add-commit protocol — assert-table-uuid + set-latest-backfilled-version.
# Backfill fires at attach time: a fresh attach sees the prior staged commit as outstanding
# and promotes it, advancing the watermark. DETACH+ATTACH forces that fresh attach (within a
# single attach the staged commit is never backfilled), so the next INSERT carries
# set-latest-backfilled-version. This mirrors the real flow where a later query backfills an
# earlier one, and keeps un-backfilled commits from accumulating (the server rejects a commit
# with HTTP 429 once too many are outstanding).
#

statement ok
DETACH duck;

statement ok
ATTACH 'duck' AS duck (TYPE unity_catalog, DEFAULT_SCHEMA 'managed');

statement ok
INSERT INTO duck.managed.id_name_rw VALUES (2, 'managed_cat_test2');

# Every add-commit carries the table UUID (assert-table-uuid requirement).
query I
SELECT count(*) > 0 FROM duckdb_logs()
WHERE message LIKE 'uc-api.UpdateTable duck.managed.id_name_rw %table_id=%'
  AND message NOT LIKE '%table_id=(none)%';
----
true

# Once the backfill watermark has advanced, later commits carry
# set-latest-backfilled-version (numeric backfill_version, not "(none)").
query I
SELECT count(*) > 0 FROM duckdb_logs()
WHERE message LIKE 'uc-api.UpdateTable duck.managed.id_name_rw %backfill_version=%'
  AND message NOT LIKE '%backfill_version=(none)%';
----
true
